# ──────────────────────────────────────────────────────────────
#  ETTAAROUF TOURISME — Variables d'environnement
#  Copier ce fichier en .env.local et remplir les valeurs
# ──────────────────────────────────────────────────────────────

# ── Site ──────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="Ettaarouf Tourisme et Voyage"

# ── Hygraph (Headless CMS) ────────────────────────────────────
# Trouvez ces valeurs dans : Project Settings > API Access
HYGRAPH_ENDPOINT=https://YOUR_REGION.cdn.hygraph.com/content/YOUR_PROJECT_ID/master
HYGRAPH_TOKEN=your_hygraph_permanent_auth_token

# ── Analytics ────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ── Contact & Notifications ───────────────────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER=213XXXXXXXXX
CONTACT_EMAIL=contact@ettaarouf-tourisme.dz
RESEND_API_KEY=re_xxxxxxxxxxxx

# ── Maps (optionnel) ──────────────────────────────────────────
# NEXT_PUBLIC_GOOGLE_MAPS_KEY=AIzaSy...

# ── Paiement (optionnel — phase 2) ───────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# NEXT_PUBLIC_STRIPE_PK=pk_live_...

# ── Revalidation Webhook (Hygraph → Netlify) ─────────────────
HYGRAPH_WEBHOOK_SECRET=your_webhook_secret_here
